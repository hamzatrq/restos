{
  "name": "restos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "turbo run test",
    "build": "turbo run build",
    "docs:lint": "node scripts/docs-lint.mjs",
    "verify": "pnpm docs:lint && pnpm typecheck && pnpm lint",
    "verify:01": "node scripts/verify-module.mjs 01"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "26.1.1",
    "turbo": "2.10.5",
    "typescript": "7.0.2"
  }
}
